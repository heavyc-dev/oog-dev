# ── oog.dev bridge config ──  (run `npm run setup` to generate this automatically)

# REQUIRED: random secret that gates access. Keep it private.
AUTH_TOKEN=change-me-to-a-long-random-string

# Folder whose immediate subdirectories become launchable "caves".
CODE_ROOT=C:\Users\You\.code

# Path/command for Claude Code (full path to the .exe is best on Windows).
CLAUDE_BIN=claude

# Network. 127.0.0.1 for local/oog.dev; your Tailscale IP only if binding directly.
BIND_HOST=127.0.0.1
# PORT defaults to 8765 (http) or 8443 (when TLS is set).
# PORT=8443

# ── HTTPS for oog.dev (see README) ──
# TLS_CERT=C:\Users\You\.oog-cert\oog.dev+4.pem
# TLS_KEY=C:\Users\You\.oog-cert\oog.dev+4-key.pem

# ── optional ──
# CC_BRIDGE_HOOK=1        # clean phone approvals via PreToolUse hook (1=on default, 0=off)
# CC_BRIDGE_PASTE=1       # send prompts as bracketed paste so multi-line input doesn't submit early (1=on default)
# RELIGHT_ON_START=1      # auto-relight remembered caves when the bridge starts
# ALLOWED_ORIGINS=https://oog.dev    # comma-list; restrict which web origins may connect
# UPLOAD_KEEP=20          # how many photos to keep per project in .oog-uploads

# ── push notifications (generated by setup; needs HTTPS) ──
# VAPID_PUBLIC=...
# VAPID_PRIVATE=...
# VAPID_SUBJECT=mailto:you@example.com
