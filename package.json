{
  "name": "oog-dev",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Run Claude Code on your PC, drive it from your phone — a pixel-caveman terminal PWA on your subscription.",
  "license": "MIT",
  "author": "heavyc-dev",
  "homepage": "https://github.com/heavyc-dev/oog-dev#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/heavyc-dev/oog-dev.git"
  },
  "bugs": {
    "url": "https://github.com/heavyc-dev/oog-dev/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "setup": "node setup.mjs",
    "setup:gui": "powershell -NoProfile -ExecutionPolicy Bypass -STA -File scripts/oog-setup-gui.ps1",
    "build:exe": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-exe.ps1",
    "install:app": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install.ps1",
    "uninstall:app": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/uninstall.ps1",
    "start": "tsx server.ts",
    "dev": "tsx watch server.ts",
    "test": "node --test",
    "typecheck": "tsc --noEmit",
    "vendor": "node scripts/vendor.mjs"
  },
  "dependencies": {
    "node-pty": "^1.0.0",
    "web-push": "^3.6.7",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.5.13",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/xterm": "^6.0.0",
    "qrcode-generator": "^2.0.4",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
